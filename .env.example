# Contact form delivery via Web3Forms (https://web3forms.com — free tier).
# Create an access key with the business's receiving email address, then set
# this in Vercel → Project → Settings → Environment Variables.
# Until it's set, the contact form accepts submissions but only logs them
# server-side (placeholder mode) — nothing is delivered.
WEB3FORMS_ACCESS_KEY=

# Canonical site URL used for hreflang/canonical/OG metadata.
# Set to the production domain once connected (defaults to the Vercel URL).
NEXT_PUBLIC_SITE_URL=https://huateng-website.vercel.app
