# Canonical site URL used for hreflang/canonical/OG metadata.
# Set to the production domain once connected (defaults to the Vercel URL).
NEXT_PUBLIC_SITE_URL=https://huateng-website.vercel.app

# Contact form delivery uses Web3Forms, submitted directly from the
# visitor's browser (their free tier blocks server-side calls). The public
# access key lives in content/site-config.json — no env var needed.
